{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:g2agents:schemas:product-frontmatter",
  "title": "G2 Agents Product Frontmatter",
  "type": "object",
  "required": [
    "type",
    "title",
    "timestamp",
    "g2_product_id",
    "vendor_id",
    "owner",
    "source_tier",
    "claim_policy"
  ],
  "properties": {
    "type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "g2_product_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "vendor_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "display_category": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "categories": {
      "deprecated": true,
      "description": "Use category_memberships instead.",
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "owner": {
      "enum": ["g2", "vendor", "shared"]
    },
    "category_memberships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category_id", "fit", "source_tier"],
        "properties": {
          "category_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "fit": {
            "enum": [
              "core",
              "adjacent",
              "partial",
              "legacy",
              "vendor-claimed",
              "disputed"
            ]
          },
          "source_tier": {
            "enum": [
              "g2-curated",
              "vendor-attested",
              "review-derived",
              "public-cited",
              "agent-inferred",
              "mixed"
            ]
          },
          "reviewed_at": {
            "type": "string",
            "format": "date"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "primary_category": {
      "deprecated": true,
      "description": "Use display_category plus category_memberships instead."
    },
    "source_tier": {
      "enum": [
        "g2-curated",
        "vendor-attested",
        "review-derived",
        "public-cited",
        "agent-inferred",
        "mixed"
      ]
    },
    "claim_policy": {
      "enum": ["cited", "attested", "synthesis", "none"]
    },
    "reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "expires_at": {
      "type": "string",
      "format": "date"
    },
    "dispute_status": {
      "enum": ["none", "open", "resolved"]
    },
    "dispute_reason": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
